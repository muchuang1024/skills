# 微信公众号配置文件模板

## 公众号信息
# 请填写你的微信公众号 AppID 和 AppSecret
# 获取方式：登录 https://mp.weixin.qq.com → 开发 → 基本配置
WECHAT_APP_ID=your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here

## 图片生成 API
# 请填写你的豆包 API Key
# 获取方式：访问火山引擎控制台 https://console.volc.com/iam/keylist
DOUBAO_API_KEY=your_doubao_api_key_here

## 文章排版配置
# 排版工具：doocs (使用 doocs/md 排版样式)
# 主题：根据文章内容动态选择（不固定）
MARKDOWN_CONVERTER=doocs
# MARKDOWN_THEME 不设置默认值，由 Agent 根据文章内容动态选择

## 文章格式配置
# 文章正文是否显示标题（false=不显示，true=显示）
ARTICLE_SHOW_TITLE=false

# 文章字数要求（默认1200-1500字）
ARTICLE_MIN_WORDS=1200
ARTICLE_MAX_WORDS=1500

## 配图配置
# 配图生成规则：
# - 仅生成文章：不生成文中配图（只输出文字内容）
# - 发布到公众号：必须生成文中配图（默认3张）
ARTICLE_IMAGE_COUNT=3

# 图片方向（horizontal=横屏，vertical=竖屏）
# 封面图和文章内配图都使用横屏格式（16:9比例）
IMAGE_ORIENTATION=horizontal

# 图片生成提示词后缀（确保生成横屏图片）
IMAGE_PROMPT_SUFFIX=，16:9横屏构图

## 使用说明
# 1. 复制本文件为 .env
# 2. 填写你的公众号 AppID、AppSecret 和豆包 API Key
# 3. 保存后即可使用
# 4. 请妥善保管 .env 文件，不要泄露给他人
