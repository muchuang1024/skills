# 阿里云百炼 API Key
# 获取地址：https://bailian.console.aliyun.com/#/api-key
# 登录后进入 "API-KEY 管理" 页面创建或复制 API Key

ALIYUN_BAILIAN_API_KEY=sk-your-api-key-here

# 可选：指定默认模型（默认：wanx2.1-t2i-plus）
# ALIYUN_MODEL=wanx2.1-t2i-plus

# 可选：指定默认图片尺寸（默认：1024x1024）
# 可选值：1024x1024, 1024x768, 768x1024, 512x512
# DEFAULT_SIZE=1024x1024
